# ControlCenter Environment Variables
# Copy this file to .env.local for local development

#----------------------------------------------
# Core Application Settings
#----------------------------------------------

# Next.js Environment
NODE_ENV=development # Options: development, production, test

#----------------------------------------------
# Database Configuration
#----------------------------------------------

# SQLite Database Path
# For local development, use a relative path to the data directory
DATABASE_URL="file:./data/controlcenter.db"

#----------------------------------------------
# Authentication Configuration
#----------------------------------------------

# NextAuth Secret (Required for JWT tokens)
# Generate a secure random string, e.g., using `openssl rand -base64 32`
NEXTAUTH_SECRET=your_secure_random_string_here

# NextAuth URL (Base URL for callbacks, required in production)
NEXTAUTH_URL=http://localhost:3000

# Session Duration (in seconds)
# Default: 1 week (604800 seconds)
NEXTAUTH_SESSION_MAX_AGE_SECONDS=604800

# Extended Session Duration for "Remember Me" (in seconds)
# Default: 30 days (2592000 seconds)
NEXTAUTH_REMEMBER_ME_MAX_AGE_SECONDS=2592000

#----------------------------------------------
# File Storage Paths
#----------------------------------------------

# Backup Storage Directory
# Path where system backups will be stored
BACKUP_STORAGE_PATH="./data/backups"

# User Avatars Directory
# Default is public/avatars
USER_AVATARS_PATH="./public/avatars"

# URL Favicons Directory
# Default is public/url_favicons
URL_FAVICONS_PATH="./public/url_favicons"

# Branding Assets Directory
# Default is public/branding
BRANDING_ASSETS_PATH="./public/branding"

#----------------------------------------------
# System Operations
#----------------------------------------------

# Log Retention Period (in days)
# 0 = Keep logs indefinitely
# Default is 180 days if not specified
LOG_RETENTION_DAYS=180

# Scheduled Task Timing (Cron Format)
# Default runs daily at 3 AM
LOG_PRUNING_CRON="0 3 * * *"

#----------------------------------------------
# Feature Flags
#----------------------------------------------

# Allow Admin User Creation
# Default is true if not specified
ALLOW_ADMIN_USER_CREATION=true

# Enable Detailed Error Logging
# Provides more detailed error information in logs
# Default is false in production
ENABLE_DETAILED_ERROR_LOGGING=true